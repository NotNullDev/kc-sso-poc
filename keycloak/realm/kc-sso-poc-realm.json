{
  "realm": "kc-sso-poc",
  "enabled": true,
  "displayName": "KC SSO POC",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "app_user",
        "description": "Base role for authenticated users allowed to access protected frontend assets."
      }
    ]
  },
  "identityProviders": [
    {
      "alias": "entra",
      "displayName": "Microsoft Entra ID",
      "providerId": "oidc",
      "enabled": false,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "acceptsPromptNoneForwardFromClient": "false",
        "authorizationUrl": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/oauth2/v2.0/authorize",
        "backchannelSupported": "false",
        "clientAuthMethod": "client_secret_post",
        "clientId": "REPLACE_WITH_ENTRA_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_ENTRA_CLIENT_SECRET",
        "defaultScope": "openid profile email",
        "disableUserInfo": "false",
        "guiOrder": "1",
        "hideOnLoginPage": "false",
        "issuer": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0",
        "jwksUrl": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/discovery/v2.0/keys",
        "logoutUrl": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/oauth2/v2.0/logout",
        "syncMode": "IMPORT",
        "tokenUrl": "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/oauth2/v2.0/token",
        "useDiscoveryEndpoint": "true",
        "userInfoUrl": "https://graph.microsoft.com/oidc/userinfo",
        "validateSignature": "true"
      }
    }
  ],
  "clients": [
    {
      "clientId": "frontend",
      "name": "Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "https://app1-sso-demo.krasisoft.com/*",
        "https://app2-sso-demo.krasisoft.com/*"
      ],
      "webOrigins": [
        "https://app1-sso-demo.krasisoft.com",
        "https://app2-sso-demo.krasisoft.com"
      ],
      "protocolMappers": [
        {
          "name": "frontend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "included.client.audience": "frontend",
            "userinfo.token.claim": "false"
          }
        }
      ],
      "secret": "change-me-frontend-client-secret"
    }
  ],
  "users": [
    {
      "username": "demo.user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "email": "demo.user@example.com",
      "realmRoles": [
        "app_user"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "ChangeMe123!",
          "temporary": false
        }
      ]
    }
  ]
}
